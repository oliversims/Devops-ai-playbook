# Lambda deploy settings — edit these, then run lambdas\deploy-lambdas.ps1
#
# DEPLOY_REGION = AWS region where deploy-lambdas creates/updates the 3 functions.
#                 (Not passed to Lambda — Lambda sets its own region automatically.)

DEPLOY_REGION=us-east-1
LOG_GROUP_NAME=/eks/boutique/pods
PROMETHEUS_URL=https://pro.simsoliver.com
DEFAULT_CLUSTER=eks-cluster
DEFAULT_NAMESPACE=boutique
